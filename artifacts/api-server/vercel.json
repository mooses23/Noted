{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "node ./build-vercel.mjs",
  "outputDirectory": ".",
  "installCommand": "pnpm install --frozen-lockfile",
  "functions": {
    "api/[...all].mts": {
      "runtime": "@vercel/node@5.1.0",
      "maxDuration": 30,
      "includeFiles": "dist/**"
    }
  }
}
