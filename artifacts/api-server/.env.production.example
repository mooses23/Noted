# =============================================================================
# layerstack-api (Vercel project)
# =============================================================================
# Copy these into the Vercel project's Environment Variables (Production +
# Preview). Do NOT commit real values.
#
# This file lists every variable read from `process.env` by the API code in
# this artifact (see `artifacts/api-server/src/**`). Anything not listed
# here is unused.

# --- Runtime ---------------------------------------------------------------
NODE_ENV=production

# Optional: pino log level. Defaults to "info".
# LOG_LEVEL=info

# --- Database (Supabase Postgres) ------------------------------------------
# Use the Supabase **Transaction Pooler** connection string (port 6543).
# It's the only mode that survives serverless cold starts cleanly. Find it in
# the Supabase dashboard under: Project Settings → Database → Connection string
# → "Transaction" pooler. Append `?sslmode=require` if not already present.
# Example:
#   postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Optional: tune the per-instance pg pool. Defaults to 1 on Vercel.
# PGPOOL_MAX=1
# PGPOOL_IDLE_TIMEOUT_MS=10000

# Optional: opt out of TLS certificate verification. DO NOT set this in
# production with Supabase — the Supabase cert is publicly trusted. Only use
# for self-hosted Postgres with a private/self-signed CA.
# PGSSL_REJECT_UNAUTHORIZED=false

# --- CORS ------------------------------------------------------------------
# Comma-separated list of fully-qualified origins allowed to call the API
# with credentials. Include the production frontend URL plus any custom
# domain. Preview URLs change per deploy — add the stable `*.vercel.app` URL
# at minimum.
# Example:
#   ALLOWED_ORIGINS=https://layerstack-web.vercel.app,https://layerstack.com
ALLOWED_ORIGINS=

# --- Clerk authentication --------------------------------------------------
# From the Clerk dashboard → API Keys.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# --- Admin allowlist -------------------------------------------------------
# Comma-separated list of email addresses granted admin privileges. Empty
# means no admins.
LAYERSTACK_ADMIN_EMAILS=

# --- Object storage (Google Cloud Storage) --------------------------------
# In production the API authenticates to GCS with a standard service
# account. In Replit dev it falls back to the Replit GCS sidecar
# automatically (no credentials env var needed). See
# `artifacts/api-server/src/lib/objectStorage.ts`.
#
# Required in production:
#   GOOGLE_APPLICATION_CREDENTIALS_JSON
#     Full service-account JSON, pasted as a single-line string. The
#     account needs Storage Object Admin (or equivalent read/write) on the
#     buckets referenced below. In Vercel, paste the JSON into the env var
#     value field — Vercel handles multi-line correctly.
#   PUBLIC_OBJECT_SEARCH_PATHS
#     Comma-separated bucket paths searched for public assets, e.g.
#     "/my-bucket/public".
#   PRIVATE_OBJECT_DIR
#     Single bucket path used for private uploads, e.g. "/my-bucket/private".
#
# Optional:
#   GCS_PROJECT_ID  Override project ID (defaults to `project_id` from the
#                   service-account JSON).
GOOGLE_APPLICATION_CREDENTIALS_JSON=
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=
# GCS_PROJECT_ID=

# --- Observability (Sentry) ------------------------------------------------
# When SENTRY_DSN is unset Sentry is fully disabled and the API behaves
# exactly as before — useful for local dev. In production set the DSN from
# your Sentry project (Settings → Client Keys (DSN)).
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
#
# Optional. Defaults to VERCEL_ENV (`production`/`preview`) or NODE_ENV.
# SENTRY_ENVIRONMENT=production
#
# Optional. Defaults to VERCEL_GIT_COMMIT_SHA so events are tagged with the
# deploy commit. Override only if you want a custom release name.
# SENTRY_RELEASE=
#
# Optional. Fraction of API requests sampled as Sentry performance
# transactions, 0..1. When unset (and SENTRY_DSN is set) the API defaults
# to 0.1, i.e. 10% of requests. That populates the "Performance" tab in
# Sentry with p50/p95/p99 latency per route, slow DB query spans, and
# slow GCS calls — without consuming the full transaction quota.
#
# Tune for your traffic & plan:
#   - 0      → disable performance tracing (errors still reported)
#   - 0.1    → default; ~okay for low-mid traffic on the Sentry Team plan
#   - 1.0    → trace every request (only on high-volume paid plans)
# SENTRY_TRACES_SAMPLE_RATE=0.1
