{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "echo 'No build step: api/[...all].ts is compiled by @vercel/node'",
  "outputDirectory": ".",
  "installCommand": "pnpm install --frozen-lockfile",
  "functions": {
    "api/[...all].ts": {
      "runtime": "@vercel/node@5.1.0",
      "maxDuration": 30
    }
  }
}
