# =============================================================================
# layerstack-web (Vercel project)
# =============================================================================
# Copy these into the Vercel project's Environment Variables (Production +
# Preview). Variables prefixed with VITE_ are inlined into the static bundle
# at build time and are publicly visible — never put secrets here.

# --- Build / runtime -------------------------------------------------------
NODE_ENV=production

# --- Routing ---------------------------------------------------------------
# Vite `base` path. Leave unset (the build defaults to "/") unless you serve
# the SPA from a sub-path.
# BASE_PATH=/

# --- Clerk (public) --------------------------------------------------------
# From the Clerk dashboard → API Keys → Publishable key.
VITE_CLERK_PUBLISHABLE_KEY=
# Optional: when using a Clerk proxy. Must match the path proxied to Clerk
# from the API project (default: /api/__clerk).
# VITE_CLERK_PROXY_URL=https://layerstack.com/api/__clerk

# --- API routing -----------------------------------------------------------
# This project does NOT take an API URL env var. The browser always calls
# `/api/*` on the same origin as the SPA, and a Vercel project-level
# rewrite (configured in the Vercel dashboard, see docs/deployment.md
# step 4.7) proxies those requests to the API project. This keeps Clerk
# session cookies on a single origin and avoids CORS.

# --- Observability (Sentry) ------------------------------------------------
# When VITE_SENTRY_DSN is unset Sentry is fully disabled in the browser.
# In production set the DSN from your Sentry project (Settings → Client Keys
# (DSN)). Use a SEPARATE Sentry project from the API so dashboards and quotas
# don't conflate the two surfaces.
# VITE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
#
# Optional. Defaults to Vite's MODE (`production`/`development`).
# VITE_SENTRY_ENVIRONMENT=production
#
# Optional. Tag events with a release name. Set to the deploy commit so
# uploaded source maps line up. On Vercel: VITE_SENTRY_RELEASE=$VERCEL_GIT_COMMIT_SHA
# VITE_SENTRY_RELEASE=
#
# Optional. Fraction of page loads sent as performance traces. 0 disables.
# VITE_SENTRY_TRACES_SAMPLE_RATE=0
